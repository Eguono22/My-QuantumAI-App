DATABASE_URL=sqlite:///./quantumai.db
# Production example:
# DATABASE_URL=postgresql://postgres:password@db:5432/quantumai
# Generate a strong random secret: openssl rand -hex 32
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
REDIS_URL=redis://redis:6379
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3004","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3004"]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_MINUTES=30
# Development can expose the reset token in the UI for pilot support.
# Set false in production once email delivery is enabled.
PASSWORD_RESET_EXPOSE_TOKEN=true
PASSWORD_RESET_DELIVERY=preview
PASSWORD_RESET_FROM_EMAIL=
PASSWORD_RESET_EMAIL_TIMEOUT_S=8.0
RESEND_API_KEY=
TRADING_MODE=paper
BROKER_PROVIDER=paper
BROKER_REQUEST_TIMEOUT_S=8.0
MARKET_DATA_PROVIDER=mock
MARKET_DATA_TIMEOUT_S=6.0
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_STARTUP_PROBE=false
ENABLE_FRONTEND_ERROR_INGEST=true
APP_VERSION=1.0.0
SIM_SLIPPAGE_BPS=1.5
SIM_FEE_BPS=2.0
SIM_PARTIAL_FILL_NOTIONAL_THRESHOLD=15000
SIM_PARTIAL_FILL_RATIO=0.7
MAX_NOTIONAL_PER_TRADE=25000
MAX_DAILY_NOTIONAL=100000
MAX_DAILY_TRADES=50
MAX_RISK_PERCENT_PER_TRADE=2.0
MQL5_BRIDGE_ENABLED=true
MQL5_SHARED_SECRET=
MQL5_TERMINAL_ACTIVE_WINDOW_S=180
MQL5_DEFAULT_CONFIDENCE_THRESHOLD=0.72
MQL5_DEFAULT_RISK_PERCENT=1.0
MQL5_DEFAULT_ORDER_QUANTITY=0.1
MQL5_MAX_AUTO_NOTIONAL=10000
APP_PUBLIC_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_REQUEST_TIMEOUT_S=12.0
